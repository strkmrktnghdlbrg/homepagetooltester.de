---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Alle Inhalte ziehen, damit die 404-Seite auf möglichst viel verlinkt
// und Besucher auf der Website hält ("Top-404-Seite").
const builders = (await getCollection("builders")).sort(
  (a, b) => a.data.rank - b.data.rank,
);
const usecases = (await getCollection("usecases")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
const articles = (await getCollection("articles")).sort((a, b) =>
  (b.data.date || "").localeCompare(a.data.date || ""),
);

const quick = [
  { href: "/baukasten-vergleich", label: "Baukasten-Vergleich 2026", sub: "Alle Tools in der großen Tabelle" },
  { href: "/baukasten-finder", label: "Baukasten-Finder", sub: "In 6 Fragen zum passenden Tool" },
  { href: "/test/onepage", label: "Testsieger: Onepage", sub: "Unser Platz 1 im Test 2026" },
  { href: "/ratgeber", label: "Ratgeber & Magazin", sub: "Anleitungen, Kosten, SEO und mehr" },
];
---

<BaseLayout
  title="Seite nicht gefunden (404) | HomepageTooltester"
  description="Diese Seite existiert nicht oder wurde verschoben. Hier findest du alle Testberichte, Vergleiche, Ratgeber und den Baukasten-Finder auf einen Blick."
  noindex={true}
>
  <section>
    <div class="wrap" style="max-width:820px;text-align:center;padding:40px 24px 16px">
      <div style="font-size:84px;font-weight:900;letter-spacing:-3px;color:var(--color-violet);line-height:1">404</div>
      <h1 style="font-size:34px;margin:8px 0 12px">Diese Seite gibt es nicht (mehr)</h1>
      <p class="muted" style="font-size:17px;max-width:560px;margin:0 auto 8px">
        Vielleicht wurde die Seite verschoben oder die Adresse hat sich vertippt.
        Nutze die Suche oder springe direkt zu einem unserer Tests, Vergleiche und Ratgeber.
      </p>
    </div>

    <div class="wrap" style="max-width:820px">
      <!-- Suche -->
      <form action="/suche" method="get" style="display:flex;gap:8px;margin:0 auto 32px;max-width:540px">
        <input type="search" name="q" placeholder="Tool, Branche oder Stichwort suchen ..."
          style="flex:1;padding:13px 16px;border:1px solid #e2e2ec;border-radius:var(--radius-btn);font-family:inherit;font-size:15px" />
        <button type="submit" class="btn btn-primary" style="width:auto">Suchen</button>
      </form>

      <!-- Direkteinstiege -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px">
        {quick.map((l) => (
          <a href={l.href} style="display:block;background:#fff;border:1px solid #ececf2;border-radius:var(--radius-card);padding:20px;text-decoration:none;color:inherit;transition:.15s">
            <div style="font-weight:900;font-size:17px">{l.label}</div>
            <div class="muted" style="font-size:14px;margin-top:4px">{l.sub}</div>
          </a>
        ))}
      </div>

      <!-- Alle Testberichte -->
      <h2 style="font-size:15px;text-transform:uppercase;letter-spacing:1px;color:var(--color-violet);margin:40px 0 14px">Alle Testberichte</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px">
        {builders.map((b) => (
          <a href={`/test/${b.data.slug}`} style="display:flex;align-items:center;justify-content:space-between;gap:10px;background:#fff;border:1px solid #ececf2;border-radius:var(--radius-card);padding:14px 16px;text-decoration:none;color:inherit">
            <span>
              <span style="font-weight:800;font-size:15px">{b.data.name}</span>
              {b.data.award && <span style="display:inline-block;margin-left:6px;font-size:11px;font-weight:800;color:var(--color-violet)">★ {b.data.award}</span>}
              <span class="muted" style="display:block;font-size:12px;margin-top:2px">{b.data.tagline}</span>
            </span>
            <span style="font-weight:900;font-size:15px;color:var(--color-violet);white-space:nowrap">{b.data.scoreOverall.toFixed(1).replace(".", ",")}</span>
          </a>
        ))}
      </div>

      <!-- Nach Anwendungsfall -->
      <h2 style="font-size:15px;text-transform:uppercase;letter-spacing:1px;color:var(--color-violet);margin:40px 0 14px">Nach Anwendungsfall</h2>
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        {usecases.map((u) => (
          <a href={`/anwendungsfall/${u.data.slug}`} style="background:#fff;border:1px solid #ececf2;border-radius:999px;padding:9px 16px;text-decoration:none;color:inherit;font-size:14px;font-weight:600">
            {u.data.accentEmoji} {u.data.title.replace(/^Bester Homepage-Baukasten für /, "").replace(/ \d{4}$/, "")}
          </a>
        ))}
      </div>

      <!-- Alle Ratgeber -->
      <h2 style="font-size:15px;text-transform:uppercase;letter-spacing:1px;color:var(--color-violet);margin:40px 0 14px">Ratgeber & Anleitungen</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px">
        {articles.map((a) => (
          <a href={`/ratgeber/${a.data.slug}`} style="display:block;background:#fff;border:1px solid #ececf2;border-radius:var(--radius-card);padding:14px 16px;text-decoration:none;color:inherit">
            <span class="muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;font-weight:700">{a.data.category}</span>
            <span style="display:block;font-weight:700;font-size:14px;margin-top:3px;line-height:1.35">{a.data.title}</span>
          </a>
        ))}
      </div>

      <!-- Tools & Service -->
      <h2 style="font-size:15px;text-transform:uppercase;letter-spacing:1px;color:var(--color-violet);margin:40px 0 14px">Tools & Service</h2>
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        <a href="/baukasten-finder" style="background:#fff;border:1px solid #ececf2;border-radius:999px;padding:9px 16px;text-decoration:none;color:inherit;font-size:14px;font-weight:600">🧭 Baukasten-Finder</a>
        <a href="/baukasten-vergleich" style="background:#fff;border:1px solid #ececf2;border-radius:999px;padding:9px 16px;text-decoration:none;color:inherit;font-size:14px;font-weight:600">📊 Großer Vergleich</a>
        <a href="/ueber-uns" style="background:#fff;border:1px solid #ececf2;border-radius:999px;padding:9px 16px;text-decoration:none;color:inherit;font-size:14px;font-weight:600">🔬 So testen wir</a>
        <a href="/kontakt" style="background:#fff;border:1px solid #ececf2;border-radius:999px;padding:9px 16px;text-decoration:none;color:inherit;font-size:14px;font-weight:600">✉️ Kontakt</a>
      </div>

      <div style="text-align:center;margin:40px 0 10px">
        <a href="/" class="btn btn-ghost">← Zur Startseite</a>
      </div>
    </div>
  </section>
</BaseLayout>
