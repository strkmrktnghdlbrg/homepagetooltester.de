---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const builders = await getCollection("builders");
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, articles, builders },
  }));
}

const { entry, articles, builders } = Astro.props;
const a = entry.data;
const { Content } = await render(entry);

// Deutsches Datum
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("de-DE", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });

// Initialen für Autoren-Avatar (E-E-A-T)
const initials = a.author
  .split(" ")
  .map((w) => w[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
const authorRole = "Redakteur Website-Tools";
const authorBio =
  a.author +
  " testet seit über acht Jahren Homepage-Baukästen und hat dabei mehr als 40 Tools praktisch geprüft. In seinen Ratgebern übersetzt er Fachthemen in verständliche Entscheidungshilfen - ohne Marketing-Floskeln.";

// Verwandte Artikel: gleiche Kategorie zuerst, dann auffüllen, max. 4
const others = articles.filter((x) => x.id !== entry.id);
const sameCat = others.filter((x) => x.data.category === a.category);
const restCat = others.filter((x) => x.data.category !== a.category);
const related = [...sameCat, ...restCat].slice(0, 4);

// Passende Baukasten-Tests: Builder suchen, deren bestFor oder Name zur Artikel-Kategorie passt
const categoryLower = (a.category || "").toLowerCase();
const titleLower = (a.title || "").toLowerCase();
const excerptLower = (a.excerpt || "").toLowerCase();
const matchedBuilders = builders.filter((bld) => {
  const bestForLower = (bld.data.bestFor || "").toLowerCase();
  const nameLower = (bld.data.name || "").toLowerCase();
  return (
    categoryLower.includes(nameLower) ||
    titleLower.includes(nameLower) ||
    excerptLower.includes(nameLower) ||
    bestForLower.split(" ").some((w: string) => w.length > 3 && categoryLower.includes(w))
  );
}).sort((x, y) => x.data.rank - y.data.rank);
// Fallback: Rang-1-Builder (Testsieger)
const topBuilderRec = matchedBuilders.length > 0
  ? matchedBuilders[0]
  : builders.slice().sort((x, y) => x.data.rank - y.data.rank)[0];

const pageDesc = a.excerpt;

const siteUrl = Astro.site?.href ?? "https://homepagetooltester.de/";
const articleUrl = new URL(`/ratgeber/${a.slug}`, siteUrl).href;
const articleImg = new URL(a.image.url, siteUrl).href;
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: a.title,
    description: a.excerpt,
    image: articleImg,
    datePublished: a.date,
    dateModified: a.date,
    inLanguage: "de-DE",
    mainEntityOfPage: articleUrl,
    author: { "@type": "Person", name: a.author },
    publisher: {
      "@type": "Organization",
      name: "HomepageTooltester",
      logo: { "@type": "ImageObject", url: new URL("/favicon.svg", siteUrl).href },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Ratgeber", item: new URL("/ratgeber", siteUrl).href },
      { "@type": "ListItem", position: 3, name: a.title },
    ],
  },
];
---

<BaseLayout title={`${a.title} - HomepageTooltester`} description={pageDesc} ogType="article" image={a.image.url} jsonLd={schema}>
  <div class="wrap">
    <div class="crumb">
      <a href="/">Home</a> › <a href="/ratgeber">Ratgeber</a> ›
      <span>{a.category}</span>
    </div>

    <div class="layout">
      <!-- MAIN -->
      <div class="content">
        <span class="badge badge-violet">{a.category}</span>
        <h1>{a.title}</h1>
        <p class="lede">{a.excerpt}</p>
        <div class="byline">
          <span class="av">{initials}</span>
          <span>
            Von <b>{a.author}</b> · {fmtDate(a.date)} · {a.readingTime} Lesezeit
          </span>
        </div>

        <!-- HERO-BILD -->
        <figure style="margin:26px 0 6px">
          <img
            src={a.image.url}
            alt={a.title}
            width="1200"
            height="630"
            loading="eager"
            style="border-radius:var(--radius-card);box-shadow:var(--shadow-card);width:100%;max-width:680px"
          />
          <figcaption
            class="muted"
            style="font-size:12px;margin-top:8px;max-width:680px"
          >
            <a href={a.image.creditUrl} rel="nofollow" style="color:var(--color-violet)"
              >{a.image.credit}</a
            >
          </figcaption>
        </figure>

        <!-- PROSE (Markdown-Body) -->
        <div class="prose">
          <Content />
        </div>

        <!-- AUTHOR E-E-A-T -->
        <div class="authorbox">
          <span class="av">{initials}</span>
          <div>
            <span class="nm">{a.author}</span> · <span class="rl">{authorRole}</span>
            <p>{authorBio}</p>
          </div>
        </div>

        <!-- Affiliate-Hinweis -->
        <p class="disclaimer" style="color:var(--color-slate-text);max-width:680px">
          Transparenz-Hinweis: Dieser Ratgeber kann Affiliate-Links enthalten.
          Schließt du über einen solchen Link einen Vertrag ab, erhalten wir eine
          Provision. Für dich entstehen keine zusätzlichen Kosten. Das hat keinen
          Einfluss auf unsere Inhalte und Bewertungen.
        </p>
      </div>

      <!-- ASIDE -->
      <aside class="aside">
        <div class="toc">
          <h4>Schnellzugriff</h4>
          <a href="/baukasten-vergleich">→ Baukasten-Vergleich</a>
          <a href="/baukasten-finder">→ Baukasten-Finder</a>
          <a href="/ratgeber">→ Alle Ratgeber</a>
          <a href="/ueber-uns">→ So testen wir</a>
        </div>

        {
          topBuilderRec && (
            <div class="verdict" style="margin-top:18px">
              <h4 style="font-size:12px;text-transform:uppercase;letter-spacing:.06em;color:var(--color-slate-text);margin-bottom:10px">
                Top-Empfehlung
              </h4>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
                <span
                  style={`width:38px;height:38px;border-radius:9px;background:${topBuilderRec.data.color};display:grid;place-items:center;color:#fff;font-weight:900;font-size:13px;flex-shrink:0`}
                >
                  {topBuilderRec.data.logoText}
                </span>
                <div>
                  <div style="font-weight:900;font-size:15px">{topBuilderRec.data.name}</div>
                  <div style="font-size:12px;color:var(--color-slate-text)">{topBuilderRec.data.bestFor}</div>
                </div>
              </div>
              <a
                href={`/test/${topBuilderRec.data.slug}`}
                class="btn btn-ghost btn-sm"
                style="width:100%"
              >
                Zum {topBuilderRec.data.name}-Test →
              </a>
            </div>
          )
        }

        <div class="verdict" style="margin-top:18px">
          <h3 style="font-size:17px;margin-bottom:8px">Noch unentschlossen?</h3>
          <p class="muted" style="font-size:14px;margin:0 0 14px">
            Unser interaktiver Finder schlägt dir in wenigen Klicks den passenden
            Baukasten vor.
          </p>
          <a
            href="/baukasten-finder"
            class="btn btn-primary btn-sm"
            style="width:100%">Finder starten →</a
          >
        </div>
      </aside>
    </div>
  </div>

  <!-- VERWANDTE ARTIKEL -->
  {
    related.length > 0 && (
      <div class="alts">
        <div class="wrap">
          <span class="eyebrow">Weiterlesen</span>
          <h2 style="margin:10px 0 0">Verwandte Ratgeber</h2>
          <div class="blog-grid" style="margin-top:24px">
            {related.map((r) => (
              <a class="post" href={`/ratgeber/${r.data.slug}`}>
                <div
                  class="thumb"
                  style={`background-image:url('${r.data.image.url}')`}
                />
                <div class="body">
                  <span class="cat">{r.data.category}</span>
                  <h3>{r.data.title}</h3>
                  <div class="meta">
                    {r.data.readingTime} Lesezeit · {r.data.author}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )
  }
</BaseLayout>
