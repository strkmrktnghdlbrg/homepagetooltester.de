---
interface Props {
  text: string;
  color: string;
  size?: number;
  class?: string;
}
const { text, color, size = 42, class: className = "" } = Astro.props;
const fontSize = Math.round(size * 0.36);
---
<span
  class={`builder-logo ${className}`}
  style={`width:${size}px;height:${size}px;background:${color};font-size:${fontSize}px;border-radius:${Math.round(size * 0.22)}px`}
>{text}</span>

<style>
  .builder-logo {
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 900;
    flex-shrink: 0;
    line-height: 1;
  }
</style>
